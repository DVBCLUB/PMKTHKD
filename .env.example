# Frontend URL của Cloudflare Worker API.
VITE_API_URL="http://localhost:8787"

# Chỉ giữ nếu frontend thật sự gọi Gemini. Không đưa secret server vào biến VITE_*.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# URL frontend hiện tại, dùng khi cần tạo callback hoặc liên kết tuyệt đối.
APP_URL="http://localhost:5173"
